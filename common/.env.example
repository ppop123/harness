# ==============================
# 环境变量示例文件
# 复制为 .env 并填写真实值
# 绝对不要把 .env 提交到 git！
# ==============================

# 基础配置
NODE_ENV=development
APP_ENV=development

# 数据库
DATABASE_URL=postgres://username:password@localhost:5432/your_db_name

# 在这里添加你的环境变量
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# REDIS_URL=redis://localhost:6379

# ===== 说明 =====
# 每个变量都应该在以下文件中注册：
# - TypeScript: src/config/env.ts
# - Python:     src/config.py
# 未注册的变量在启动时会报错（这是故意的）
